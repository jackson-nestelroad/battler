{
  "guardspec": {
    "name": "Guard Spec.",
    "target": "Active",
    "flags": ["Battle"],
    "effect": {
      "callbacks": {
        "on_player_try_use_item": ["require !func_call(has_side_condition: $target.side mist)"],
        "on_player_use": ["add_side_condition: $mon.side mist", "increase_friendship: $mon 1 1 0"]
      }
    }
  },
