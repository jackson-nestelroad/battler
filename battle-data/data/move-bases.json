{
  "breakprotectmovebase": {
    "name": "Break Protect Move Base",
    "condition_type": "Built-in",
    "condition": {
      "callbacks": {
        "on_try_hit": ["add_volatile: $target breakprotect"]
      }
    }
  },
  "protectmovebase": {
    "name": "Protect Move Base",
    "condition_type": "Built-in",
    "condition": {
      "callbacks": {
        "on_prepare_hit": [
          "return func_call(any_mon_will_move_this_turn) and func_call(run_event_for_mon: StallMove)"
        ],
        "on_hit": ["add_volatile: $target stall"]
      }
    }
  },
  "protectmoveconditionbase": {
    "name": "Protect Move Condition Base",
    "condition_type": "Built-in",
    "condition": {
      "duration": 1,
      "delegates": ["condition:weakenthroughprotectionmovebase"],
      "callbacks": {
        "on_start": [
          "log_single_turn: with_target",
          "add_volatile: $target $source_effect.id link"
        ],
        "on_try_hit": {
          "priority": 3,
          "program": [
            "require func_call(move_has_flag: $move protect) else return",
            "if $report:",
            ["log_activate: with_target"],
            "activate_applying_effect: $this no_forward",
            "if $effect_state.source_effect.is_defined:",
            ["activate_applying_effect: $effect_state.source_effect no_forward"],
            "return stop"
          ]
        },
        "on_hit": [
          "if $move.upgraded:",
          [
            "activate_applying_effect: $this no_forward",
            "if $effect_state.source_effect.is_defined:",
            ["activate_applying_effect: $effect_state.source_effect no_forward"]
          ]
        ]
      }
    }
  },
  "chargemovebase": {
    "name": "Charge Move Base",
    "condition_type": "Built-in",
    "condition": {
      "callbacks": {
        "on_try_use_move": [
          "require !func_call(remove_volatile: $user $this.id) else return",
          "log_prepare_move",
          "run_event: BeforeChargeMove",
          "$charge_move = func_call(run_event_on_move: ChargeMove)",
          "if $charge_move.is_defined and !$charge_move:",
          ["do_not_animate_last_move", "log_animate_move: $move $target", "return"],
          "if !func_call(run_event: ChargeMove):",
          ["do_not_animate_last_move", "log_animate_move: $move $target", "return"],
          "add_volatile: $user twoturnmove link",
          "return stop"
        ]
      }
    }
  },
  "weakenthroughprotectionmovebase": {
    "name": "Weaken Through Protection Move Base",
    "condition_type": "Built-in",
    "condition": {
      "callbacks": {
        "on_source_modify_damage": [
          "if func_call(move_has_flag: $move weakenthroughprotection):",
          [
            "if $move.effect_state.weaken_through_protection_effect.is_defined and $move.effect_state.weaken_through_protection_source.is_defined:",
            [
              "log_activate: $move.effect_state.weaken_through_protection_effect with_target $move.effect_state.weaken_through_protection_source"
            ],
            "log_custom_effect: protectweaken no_effect with_target use_source",
            "return $damage / 4"
          ]
        ]
      }
    }
  },
  "defogmovebase": {
    "name": "Defog Move Base",
    "condition_type": "Built-in",
    "condition": {
      "callbacks": {
        "on_hit": [
          "$remove_from_target_side = [reflect, lightscreen, auroraveil, safeguard, mist]",
          "$remove_from_both_sides = [spikes, toxicspikes, stealthrock, stickyweb, gmaxsteelsurge]",
          "$success = false",
          "$target_side = $target.side",
          "if func_call(value_from_local_data: use_source_foe_side) == 'true':",
          ["$target_side = $source.foe_side"],
          "foreach $condition in $remove_from_target_side:",
          ["if func_call(remove_side_condition: $target_side $condition):", ["$success = true"]],
          "foreach $condition in $remove_from_both_sides:",
          [
            "foreach $side in $field.sides:",
            ["if func_call(remove_side_condition: $side $condition):", ["$success = true"]]
          ],
          "clear_terrain",
          "return $success"
        ]
      }
    }
  },
  "pledgemovebase": {
    "name": "Pledge Move Base",
    "condition_type": "Built-in",
    "condition": {
      "callbacks": {
        "on_prepare_hit": [
          "require !$move.effect_state.source_effect or !func_call(move_has_flag: $move.effect_state.source_effect.id pledgecombo) else return",
          "foreach $action in func_call(pending_move_actions_this_turn):",
          [
            "if !$action.mon.active or $action.mon.fainted:",
            ["continue"],
            "$other_move_id = $action.effective_id",
            "if func_call(is_ally: $user $action.mon) and $other_move_id != $this.id and func_call(move_has_flag: $other_move_id pledgecombo):",
            ["prioritize_move: $action.mon $this", "log_waiting: $user $action.mon", "return stop"]
          ]
        ],
        "on_move_base_power": [
          "if $move.effect_state.source_effect.is_defined and $move.effect_state.source_effect.id != $this.id and func_call(move_has_flag: $move.effect_state.source_effect pledgecombo):",
          ["log: combine", "return 150"]
        ]
      }
    }
  },
  "ignoreabilitymovebase": {
    "name": "Ignore Ability Move Base",
    "condition_type": "Built-in",
    "condition": {
      "duration": 1,
      "callbacks": {
        "on_before_move": ["add_pseudo_weather: moldbreaker"],
        "on_move_aborted": ["run_event_on_move: AfterMove"],
        "on_after_move": ["remove_pseudo_weather: moldbreaker"]
      }
    }
  },
  "windingupmovebase": {
    "name": "Winding Up Move Base",
    "condition_type": "Built-in",
    "condition": {
      "duration": 1,
      "callbacks": {
        "on_priority_charge_move": ["add_volatile: $mon windingup"]
      }
    }
  },
  "sidescreenmovebase": {
    "name": "Side Screen Move Base",
    "condition_type": "Built-in",
    "condition": {
      "duration": 5,
      "callbacks": {
        "on_source_modify_damage": [
          "$category = func_call(value_from_local_data: category)",
          "require $target != $user and (!$category or $move.category == $category) else return",
          "require !$move.effect_state.screen_weaken else return",
          "require !func_call(move_crit_target: $move $target) and !$move.effect_state.infiltrates else return",
          "$move.effect_state.screen_weaken = true",
          "if $format.mons_per_side > 1:",
          ["return $damage * 2 / 3"],
          "return $damage / 2"
        ],
        "on_side_start": ["log_side_start"],
        "on_side_end": ["log_side_end"]
      }
    }
  },
  "cannotusetwicemovebase": {
    "name": "Cannot Use Twice Move Base",
    "condition_type": "Built-in",
    "condition": {
      "callbacks": {
        "on_disable_move": [
          "if $mon.last_move.is_defined and $mon.last_move.id == $this.id:",
          ["disable_move: $mon $this.id"]
        ]
      }
    }
  }
}
