  "burnup": {
    "name": "Burn Up",
    "category": "Special",
    "primary_type": "Fire",
    "base_power": 130,
    "accuracy": 100,
    "pp": 5,
    "target": "Normal",
    "flags": ["Mirror", "Protect", "Thawing"],
    "user_effect": {},
    "effect": {
      "callbacks": {
        "on_try_move": [
          "if func_call(has_type: $user fire):",
          ["return"],
          "log_fail: $user",
          "do_not_animate_last_move",
          "return stopfail"
        ],
        "on_hit_user": [
          "# Remove Fire type.",
          "# Note that if we are forced into the Fire type (e.g., Terastallization), this has no effect.",
          "$types = []",
          "foreach $type in $source.types:",
          ["if $type == fire:", ["continue"], "$types = func_call(append: $types $type)"],
          "set_types: $target $types"
        ]
      }
    }
  },
