  "throatchop": {
    "name": "Throat Chop",
    "category": "Physical",
    "primary_type": "Dark",
    "base_power": 80,
    "accuracy": 100,
    "pp": 15,
    "target": "Normal",
    "flags": ["Contact", "Mirror", "Protect"],
    "hit_effect": {
      "volatile_status": "throatchop"
    },
    "condition": {
      "callbacks": {
        "on_start": ["log_start: silent"],
        "on_disable_move": [
          "foreach $move_slot in $mon.move_slots:",
          [
            "if func_call(move_has_flag: $move_slot.id sound):",
            ["disable_move: $mon $move_slot.id"]
          ]
        ],
        "on_before_move": [
          "if !$move.upgraded and func_call(move_has_flag: $move sound):",
          ["log_cant", "return false"]
        ],
        "on_try_move": ["return func_call(run_event_on_move: BeforeMove)"],
        "on_end": ["log_end: silent"]
      }
    }
  },
  "pollenpuff": {
