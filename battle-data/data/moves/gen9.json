  "doodle": {
    "name": "Doodle",
    "category": "Status",
    "primary_type": "Normal",
    "accuracy": 100,
    "pp": 10,
    "target": "AdjacentFoe",
    "flags": ["NoMetronome"],
    "effect": {
      "callbacks": {
        "on_hit": [
          "require !func_call(ability_has_flag: $target.ability permanent) and !func_call(ability_has_flag: $target.ability noroleplay)",
          "$success = func_call(event_result: false)",
          "foreach $mon in func_call(allies_and_self: $source):",
          [
            "if $mon.ability == $target.ability or func_call(ability_has_flag: $mon.ability permanent):",
            ["continue"],
            "$set_ability = func_call(set_ability: $mon $target.ability)",
            "if $set_ability:",
            ["$success = true"],
            "else if !$success and $set_ability != false:",
            ["$success = $set_ability"]
          ],
          "return $success"
        ]
      }
    }
  },
