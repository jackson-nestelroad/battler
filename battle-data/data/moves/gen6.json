    "z_move": { "boosts": { "def": 1 } },
    "effect": {
      "callbacks": {
        "on_try_use_move": [
          "return $user.active_turns <= 1 and func_call(any_mon_will_move_this_turn)"
        ]
      }
    },
    "condition": {
      "duration": 1,
      "delegates": ["condition:weakenthroughprotectionmovebase"],
      "callbacks": {
        "on_side_start": ["log_single_turn: use_source with_target"],
        "on_try_hit": {
          "priority": 3,
          "program": [
            "if !func_call(move_has_flag: $move protect):",
            ["return"],
            "if $move.target == user or $move.category == status:",
            ["return"],
            "log_activate: with_target",
            "return stop"
          ]
        }
      }
    }
  },
