  "grassyterrain": {
    "name": "Grassy Terrain",
    "category": "Status",
    "primary_type": "Grass",
    "pp": 10,
    "accuracy": "exempt",
    "target": "Field",
    "flags": [],
    "hit_effect": { "terrain": "grassyterrain" },
    "z_move": { "boosts": { "def": 1 } },
    "condition": {
      "duration": 5,
      "callbacks": {
        "on_duration": [
          "if func_call(has_item: $source terrainextender):",
          ["return 8"]
        ],
        "on_field_start": [
          "if !$source:",
          ["return"],
          "if $source_effect.is_ability:",
          ["log_field_start: with_source_effect"],
          "else:",
          ["log_field_start"]
        ],
        "on_field_end": ["log_field_end"],
        "on_source_base_power": [
          "$weakened = [earthquake, bulldoze, magnitude]",
          "if $weakened has $move.id:",
          ["return $base_power * 1/2"],
          "if $move.type == grass:",
          ["return $base_power * 13/10"]
        ],
        "on_residual": ["heal: $target expr($target.base_max_hp / 16)"]
      }
    }
  },
  "mistyterrain": {
    "name": "Misty Terrain",
    "category": "Status",
    "primary_type": "Fairy",
    "pp": 10,
    "accuracy": "exempt",
    "target": "Field",
    "flags": [],
    "hit_effect": { "terrain": "mistyterrain" },
    "z_move": { "boosts": { "spd": 1 } },
    "condition": {
      "duration": 5,
      "callbacks": {
        "on_duration": [
          "if func_call(has_item: $source terrainextender):",
          ["return 8"]
        ],
        "on_field_start": [
          "if !$source:",
          ["return"],
          "if $source_effect.is_ability:",
          ["log_field_start: with_source_effect"],
          "else:",
          ["log_field_start"]
        ],
        "on_field_end": ["log_field_end"],
        "on_base_power": [
          "if $move.type == dragon:",
          ["return $base_power * 1/2"]
        ],
        "on_set_status": [
          "if $effect.id == yawn or ($effect.is_move and !$effect.is_move_secondary):",
          ["log_activate: with_target"],
          "return false"
        ],
        "on_add_volatile": [
          "if $volatile.id == yawn or $volatile.id == confusion:",
          [
            "if $effect.is_move and !$effect.is_move_secondary:",
            ["log_activate: with_target"],
            "return false"
          ]
        ]
      }
    }
  },
