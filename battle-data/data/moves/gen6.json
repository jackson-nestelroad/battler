            "return false"
          ]
        ],
        "on_add_volatile": [
          "if $volatile.id == yawn:",
          ["log_activate: with_target", "return false"]
        ],
        "on_source_base_power": [
          "if $move.type == electric:",
          ["return $base_power * 13/10"]
