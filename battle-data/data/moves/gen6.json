  "matblock": {
    "name": "Mat Block",
    "category": "Status",
    "primary_type": "Fighting",
    "pp": 10,
    "accuracy": "exempt",
    "target": "AllySide",
    "flags": ["FailCopycat", "NoAssist", "NoMetronome", "Snatch", "Stalling"],
