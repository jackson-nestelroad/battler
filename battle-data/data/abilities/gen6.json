  "aurabreak": {
    "name": "Aura Break",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_start": ["log_ability"],
        "on_any_try_primary_hit": ["$move.effect_state.aura_break = true"]
      }
    }
  },
  "primordialsea": {
    "name": "Primordial Sea",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": [
          "$effect_state.active = true",
          "set_weather: heavyrainweather"
        ],
        "on_set_weather": [
          "$strong_weathers = [extremelyharshsunlight, heavyrainweather, strongwinds]",
          "if $field.weather == heavyrainweather and !($strong_weathers has $weather):",
          ["return false"]
        ],
        "on_clear_weather": ["if $effect_state.active:", ["return false"]],
        "on_end": [
          "if $field.weather != heavyrainweather:",
          ["return"],
          "$effect_state.active = false",
          "clear_weather"
        ]
      }
    }
  },
  "desolateland": {
    "name": "Desolate Land",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": [
          "$effect_state.active = true",
          "set_weather: extremelyharshsunlight"
        ],
        "on_set_weather": [
          "$strong_weathers = [extremelyharshsunlight, heavyrainweather, strongwinds]",
          "if $field.weather == extremelyharshsunlight and !($strong_weathers has $weather):",
          ["return false"]
        ],
        "on_clear_weather": ["if $effect_state.active:", ["return false"]],
        "on_end": [
          "if $field.weather != extremelyharshsunlight:",
          ["return"],
          "$effect_state.active = false",
          "clear_weather"
        ]
      }
    }
  },
  "deltastream": {
    "name": "Delta Stream",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": ["$effect_state.active = true", "set_weather: strongwinds"],
        "on_set_weather": [
          "$strong_weathers = [extremelyharshsunlight, heavyrainweather, strongwinds]",
          "if $field.weather == strongwinds and !($strong_weathers has $weather):",
          ["return false"]
        ],
        "on_clear_weather": ["if $effect_state.active:", ["return false"]],
        "on_end": [
          "if $field.weather != strongwinds:",
          ["return"],
          "$effect_state.active = false",
          "clear_weather"
        ]
      }
    }
  }
}
