{
  "aromaveil": {
    "name": "Aroma Veil",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_ally_add_volatile": [
          "require [attract, disable, encore, healblock, taunt, torment] has $volatile.id else return",
          "if $effect.is_move:",
          ["log_block: with_target"],
          "return stopfail"
        ]
      }
    }
  },
  "flowerveil": {
    "name": "Flower Veil",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_ally_try_boost": [
          "require (!$source or $target != $source) and func_call(has_type: $target grass) else return",
          "$cleared = []",
          "foreach $boost in func_call(boostable_stats):",
          [
            "if func_call(get_boost: $boosts $boost) < 0:",
            [
              "$boosts = func_call(set_boost: $boosts $boost 0)",
              "$cleared = func_call(append: $cleared $boost)"
            ]
          ],
          "if !$cleared.is_empty and !$effect.is_move_secondary:",
          ["log_fail_unboost: from_effect $cleared"],
          "return $boosts"
        ],
        "on_ally_set_status": [
          "require !$source or $target != $source else return",
          "require func_call(has_type: $target grass) else return",
          "require $effect.id != yawn else return",
          "if $effect.is_move and !$effect.is_move_secondary:",
          ["log_block: with_target"],
          "return stopfail"
        ],
        "on_ally_add_volatile": [
          "require (!$source or $target != $source) and func_call(has_type: $target grass) else return",
          "if $volatile.id == yawn:",
          [
            "if $effect.is_move and !$effect.is_move_secondary:",
            ["log_block: with_target"],
            "return stopfail"
          ]
        ]
      }
    }
  },
  "cheekpouch": {
    "name": "Cheek Pouch",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_eat_item": ["heal: $target expr($target.base_max_hp / 3)"]
      }
    }
  },
  "protean": {
    "name": "Protean",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_prepare_hit": [
          "require !$effect_state.activated else return",
          "require !$move.effect_state.reflected else return",
          "require !func_call(move_has_flag: $move future) else return",
          "require !func_call(move_has_flag: $move callsmove) else return",
          "require $move.type != none else return",
          "require func_call(set_types: $user [$move.type]) else return",
          "$effect_state.activated = true"
        ],
        "on_after_mega_evolution": ["$effect_state.activated = false"]
      }
    }
  },
  "furcoat": {
    "name": "Fur Coat",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_modify_def": ["return $def * 2"]
      }
    }
  },
  "magician": {
    "name": "Magician",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_after_move_secondary_effects_user": [
          "require !$user.needs_switch else return",
          "require !$move.damaged_targets.is_empty else return",
          "require !$user.item else return",
          "require !func_call(has_volatile: $user gem) else return",
          "require $move.id != fling else return",
          "require $move.category != status else return",
          "foreach $mon in func_call(speed_sort_mons: $move.damaged_targets):",
          [
            "if $mon == $user:",
            ["continue"],
            "$item = undefined",
            "$item = func_call(take_item: $mon dry_run)",
            "if !$item or !func_call(set_item: $user $item dry_run):",
            ["continue"],
            "$item = func_call(take_item: $mon)",
            "if !$item:",
            ["continue"],
            "set_item: $user $item",
            "break"
          ]
        ]
      }
    }
  },
  "bulletproof": {
    "name": "Bulletproof",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_try_hit": [
          "if $target != $source and func_call(move_has_flag: $move bullet):",
          ["if $report:", ["log_immune: $target from_effect"], "return stopfail"]
        ]
      }
    }
  },
  "competitive": {
    "name": "Competitive",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_after_each_boost": [
          "require $source.is_defined and !func_call(is_ally: $target $source) else return",
          "if $value < 0:",
          ["boost: $target 'spa:2'"]
        ]
      }
    }
  },
  "strongjaw": {
    "name": "Strong Jaw",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_source_base_power": [
          "if func_call(move_has_flag: $move bite):",
          ["return $base_power * 3/2"]
        ]
      }
    }
  },
  "refrigerate": {
    "name": "Refrigerate",
    "flags": [],
    "effect": {
      "delegates": ["condition:modifynormaltypemoveabilitybase"],
      "local_data": {
        "values": {
          "type": "ice"
        }
      }
    }
  },
  "sweetveil": {
    "name": "Sweet Veil",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_ally_set_status": [
          "if $status.id == slp:",
          ["log_block: with_target", "return stopfail"]
        ],
        "on_ally_add_volatile": [
          "if $volatile.id == yawn:",
          [
            "if $effect.is_move and !$effect.is_move_secondary:",
            ["log_block: with_target"],
            "return stopfail"
          ]
        ]
      }
    }
  },
  "stancechange": {
    "name": "Stance Change",
    "flags": [
      "NoEntrainment",
      "NoReceiver",
      "NoRolePlay",
      "NoSkillSwap",
      "NoTrace",
      "NoTransform",
      "Permanent"
    ],
    "effect": {
      "callbacks": {
        "on_use_move": [
          "require func_call(base_species: $user) == aegislash else return",
          "require $move.category != status or $move.id == kingsshield else return",
          "$species = aegislashblade",
          "if $move.id == kingsshield:",
          ["$species = aegislash"],
          "if $user.species != $species:",
          ["forme_change: $user $species"]
        ]
      }
    }
  },
  "galewings": {
    "name": "Gale Wings",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_modify_priority": [
          "if $move.type == flying and $user.hp == $user.max_hp:",
          ["return $priority + 1"]
        ]
      }
    }
  },
  "megalauncher": {
    "name": "Mega Launcher",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_source_base_power": [
          "if func_call(move_has_flag: $move pulse):",
          ["return $base_power * 3/2"]
        ],
        "on_prepare_hit": ["if $move.id == healpulse:", ["$move.effect_state.multiplier = 3/4"]]
      }
    }
  },
  "grasspelt": {
    "name": "Grass Pelt",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_modify_def": ["if $target.effective_terrain == grassyterrain:", ["return $def * 3/2"]]
      }
    }
  },
  "symbiosis": {
    "name": "Symbiosis",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_ally_after_use_item": [
          "require !$target.needs_switch else return",
          "$source = $effect_state.target",
          "require !!assign($ally_item = func_call(take_item: $source dry_run)) and func_call(set_item: $target $ally_item dry_run) else return",
          "require !!assign($ally_item = func_call(take_item: $source)) else return",
          "set_item: $target $ally_item"
        ]
      }
    }
  },
  "toughclaws": {
    "name": "Tough Claws",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_source_base_power": [
          "if func_call(move_has_flag: $move contact):",
          ["return $base_power * 13/10"]
        ]
      }
    }
  },
  "pixilate": {
    "name": "Pixilate",
    "flags": [],
    "effect": {
      "delegates": ["condition:modifynormaltypemoveabilitybase"],
      "local_data": {
        "values": {
          "type": "fairy"
        }
      }
    }
  },
  "gooey": {
    "name": "Gooey",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": [
          "if func_call(move_makes_contact: $move):",
          ["log_ability", "boost: $source 'spe:-1'"]
        ]
      }
    }
  },
  "aerilate": {
    "name": "Aerilate",
    "flags": [],
    "effect": {
      "delegates": ["condition:modifynormaltypemoveabilitybase"],
      "local_data": {
        "values": {
          "type": "flying"
        }
      }
    }
  },
  "parentalbond": {
    "name": "Parental Bond",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_prepare_hit": [
          "require $move.category != status else return",
          "require !$move.multihit else return",
          "require !func_call(move_has_flag: $move noparentalbond) else return",
          "require !func_call(move_has_flag: $move charge) else return",
          "require !func_call(move_has_flag: $move future) else return",
          "require !$move.spread_hit else return",
          "require !$move.upgraded else return",
          "$move.multihit = 2",
          "$move.effect_state.parental_bond = true"
        ],
        "on_modify_damage": [
          "if $move.hit > 1 and $move.effect_state.parental_bond:",
          ["return $damage / 4"]
        ]
      }
    }
  },
  "darkaura": {
    "name": "Dark Aura",
    "flags": [],
    "effect": {
      "delegates": ["condition:auraabilitybase"],
      "local_data": {
        "values": {
          "type": "dark"
        }
      }
    }
  },
  "fairyaura": {
    "name": "Fairy Aura",
    "flags": [],
    "effect": {
      "delegates": ["condition:auraabilitybase"],
      "local_data": {
        "values": {
          "type": "fairy"
        }
      }
    }
  },
  "aurabreak": {
    "name": "Aura Break",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_start": ["log_ability"],
        "on_any_try_primary_hit": ["$move.effect_state.aura_break = true"]
      }
    }
  },
  "primordialsea": {
    "name": "Primordial Sea",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": ["$effect_state.active = true", "set_weather: heavyrainweather"],
        "on_set_weather": [
          "$strong_weathers = [extremelyharshsunlight, heavyrainweather, strongwinds]",
          "require $field.weather != heavyrainweather or $strong_weathers has $weather else return false"
        ],
        "on_clear_weather": ["require !$effect_state.active else return false"],
        "on_end": [
          "require $field.weather == heavyrainweather else return",
          "$effect_state.active = false",
          "clear_weather"
        ]
      }
    }
  },
  "desolateland": {
    "name": "Desolate Land",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": ["$effect_state.active = true", "set_weather: extremelyharshsunlight"],
        "on_set_weather": [
          "$strong_weathers = [extremelyharshsunlight, heavyrainweather, strongwinds]",
          "require $field.weather != extremelyharshsunlight or $strong_weathers has $weather else return false"
        ],
        "on_clear_weather": ["require !$effect_state.active else return false"],
        "on_end": [
          "require $field.weather == extremelyharshsunlight else return",
          "$effect_state.active = false",
          "clear_weather"
        ]
      }
    }
  },
  "deltastream": {
    "name": "Delta Stream",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": ["$effect_state.active = true", "set_weather: strongwinds"],
        "on_set_weather": [
          "$strong_weathers = [extremelyharshsunlight, heavyrainweather, strongwinds]",
          "require $field.weather != strongwinds or $strong_weathers has $weather else return false"
        ],
        "on_clear_weather": ["if $effect_state.active:", ["return false"]],
        "on_end": [
          "require $field.weather == strongwinds else return",
          "$effect_state.active = false",
          "clear_weather"
        ]
      }
    }
  }
}
