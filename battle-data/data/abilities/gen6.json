        }
      }
    }
  },
  "parentalbond": {
    "name": "Parental Bond",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_prepare_hit": [
          "if $move.category == status or $move.multihit.is_defined or func_call(move_has_flag: $move noparentalbond) or func_call(move_has_flag: $move charge) or func_call(move_has_flag: $move future) or $move.spread_hit or $move.upgraded:",
          ["return"],
          "$move.multihit = 2",
          "$move.effect_state.parental_bond = true"
        ],
        "on_modify_damage": [
          "if $move.hit > 1 and $move.effect_state.parental_bond:",
          ["return $damage / 4"]
        ]
      }
    }
  },
  "darkaura": {
