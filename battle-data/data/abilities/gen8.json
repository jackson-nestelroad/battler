{
  "intrepidsword": {
    "name": "Intrepid Sword",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": [
          "require !$effect_state.boosted else return",
          "$effect_state.boosted = true",
          "boost: $target 'atk:1'"
        ]
      }
    }
  },
  "dauntlessshield": {
    "name": "Dauntless Shield",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": [
          "require !$effect_state.boosted else return",
          "$effect_state.boosted = true",
          "boost: $target 'def:1'"
        ]
      }
    }
  },
  "libero": {
    "name": "Libero",
    "flags": [],
    "effect": {
      "delegates": ["ability:protean"]
    }
  },
  "ballfetch": {
    "name": "Ball Fetch",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_any_catch_failed": [
          "require !$effect_state.first_ball else return",
          "$effect_state.first_ball = $item"
        ],
        "on_residual": [
          "require !$effect_state.activated else return",
          "require $effect_state.first_ball.is_defined else return",
          "require !$target.item else return",
          "$effect_state.activated = true",
          "set_item: $target $effect_state.first_ball"
        ]
      }
    }
  },
  "cottondown": {
    "name": "Cotton Down",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": [
          "$activated = false",
          "foreach $mon in func_call(all_active_mons):",
          [
            "if $mon == $target:",
            ["continue"],
            "if !$activated:",
            ["$activated = true", "log_activate: with_target"],
            "boost: $mon 'spe:-1'"
          ]
        ]
      }
    }
  },
  "propellertail": {
    "name": "Propeller Tail",
    "flags": [],
    "effect": {
      "delegates": ["ability:stalwart"]
    }
  },
  "mirrorarmor": {
    "name": "Mirror Armor",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_try_boost": [
          "require $source.is_defined else return",
          "require $target != $source else return",
          "require $effect != $this.id else return",
          "$cleared = func_call(boost_table)",
          "foreach $boost in func_call(boostable_stats):",
          [
            "$val = func_call(get_boost: $boosts $boost)",
            "if $val < 0:",
            [
              "$boosts = func_call(set_boost: $boosts $boost 0)",
              "$cleared = func_call(set_boost: $cleared $boost $val)"
            ]
          ],
          "if !$cleared.is_empty and $source.hp > 0:",
          ["log_ability", "boost: $source $cleared"],
          "return $boosts"
        ]
      }
    }
  },
  "gulpmissile": {
    "name": "Gulp Missile",
    "flags": ["NoTransform", "Permanent"],
    "effect": {
      "callbacks": {
        "on_before_charge_move": ["require $move.id == dive else return", "activate_ability"],
        "on_source_try_primary_hit": [
          "require $move.id == surf else return",
          "activate_ability: $source"
        ],
        "on_activate": [
          "require $target.species == cramorant else return",
          "$forme = cramorantgulping",
          "if $target.hp <= $target.max_hp / 2:",
          ["$forme = cramorantgorging"],
          "forme_change: $target $forme"
        ],
        "on_damaging_hit": [
          "require $source.hp != 0 else return",
          "require $source.active else return",
          "require !$target.is_semi_invulnerable else return",
          "require $target.species != cramorant else return",
          "$base_species = func_call(base_species: $target)",
          "require $base_species == cramorant else return",
          "damage: $source expr($source.base_max_hp / 4)",
          "if $target.species == cramorantgulping:",
          ["boost: $source 'def:-1'"],
          "else if $target.species == cramorantgorging:",
          ["set_status: $source par"],
          "forme_change: $target cramorant"
        ]
      }
    }
  },
  "stalwart": {
    "name": "Stalwart",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_use_move": ["if $move.target != scripted:", ["$move.tracks_target = true"]]
      }
    }
  },
  "steamengine": {
    "name": "Steam Engine",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": ["if [fire, water] has $move.type:", ["boost: $target 'spe:6'"]]
      }
    }
  },
  "punkrock": {
    "name": "Punk Rock",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_source_base_power": [
          "if func_call(move_has_flag: $move sound):",
          ["return $base_power * 13/10"]
        ],
        "on_source_modify_damage": [
          "if func_call(move_has_flag: $move sound):",
          ["return $damage / 2"]
        ]
      }
    }
  },
  "sandspit": {
    "name": "Sand Spit",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": ["set_weather: sandstormweather"]
      }
    }
  },
  "icescales": {
    "name": "Ice Scales",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_source_modify_damage": ["if $move.category == special:", ["return $damage / 2"]]
      }
    }
  },
  "ripen": {
    "name": "Ripen",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_try_heal": [
          "if $effect.id == berryjuice or $effect.id == leftovers or ($effect.is_item and func_call(item_has_flag: $effect.id berry)):",
          ["log_activate: with_target", "return $damage * 2"]
        ],
        "on_try_boost": [
          "if $effect.is_item and func_call(item_has_flag: $effect.id berry):",
          [
            "foreach $stat in func_call(boostable_stats):",
            [
              "$boosts = func_call(set_boost: $boosts $stat expr(func_call(get_boost: $boosts $stat) * 2))"
            ],
            "return $boosts"
          ]
        ],
        "on_try_eat_item": {
          "priority": -1,
          "program": ["log_activate: with_target"]
        },
        "on_eat_item": [
          "if func_call(item_has_flag: $item.id damagereducingberry):",
          ["$effect_state.berry_weaken = true"]
        ],
        "on_source_modify_damage": {
          "priority": -1,
          "program": [
            "if $effect_state.berry_weaken:",
            ["$effect_state.berry_weaken = false", "return $damage / 2"]
          ]
        },
        "on_damage": [
          "if $effect.is_item and func_call(item_has_flag: $effect.id berry):",
          ["return $damage * 2"]
        ],
        "on_restore_pp": [
          "if $effect.is_item and func_call(item_has_flag: $effect.id berry):",
          ["return $pp * 2"]
        ]
      }
    }
  },
  "iceface": {
    "name": "Ice Face",
    "flags": [
      "Breakable",
      "NoEntrainment",
      "NoReceiver",
      "NoRolePlay",
      "NoSkillSwap",
      "NoTrace",
      "NoTransform",
      "Permanent"
    ],
    "effect": {
      "callbacks": {
        "on_damage": {
          "priority": 1,
          "program": [
            "require $effect.is_move else return",
            "require $effect.category == physical else return",
            "require $target.species == eiscue else return",
            "forme_change: $target eiscuenoice permanent",
            "return 0"
          ]
        },
        "on_critical_hit": [
          "require $target.species == eiscue else return",
          "require $move.category == physical else return",
          "require !func_call(move_hit_data_has_flag_against_target: $move $target hitsubstitute) else return",
          "require !func_call(check_move_immunity: $target $move) else return",
          "return false"
        ],
        "on_effectiveness": [
          "if func_call(run_event_on_mon_ability: CriticalHit use_source_effect no_forward) == false:",
          ["return 0"]
        ],
        "on_weather_change": [
          "require $target.species == eiscuenoice else return",
          "$weather = func_call(effective_weather: $target use_target_as_origin)",
          "if $weather.is_defined and $weather.is_snowing:",
          ["forme_change: $target eiscue permanent"]
        ],
        "on_start": ["run_event_on_mon_ability: WeatherChange"]
      }
    }
  },
  "powerspot": {
    "name": "Power Spot",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_any_base_power": [
          "require $source != $effect_state.target and func_call(is_ally: $source $effect_state.target) else return",
          "return $base_power * 13/10"
        ]
      }
    }
  },
  "mimicry": {
    "name": "Mimicry",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": ["run_event_on_mon_ability: TerrainChange"],
        "on_terrain_change": [
          "$terrain = $field.effective_terrain",
          "$types = []",
          "if $terrain == electricterrain:",
          ["$types = [electric]"],
          "else if $terrain == grassyterrain:",
          ["$types = [grass]"],
          "else if $terrain == mistyterrain:",
          ["$types = [fairy]"],
          "else if $terrain == psychicterrain:",
          ["$types = [psychic]"],
          "if $types.is_empty:",
          ["reset_types: $target"],
          "else:",
          ["set_types: $target $types"]
        ]
      }
    }
  },
  "screencleaner": {
    "name": "Screen Cleaner",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": [
          "$side_conditions = [lightscreen, reflect, auroraveil]",
          "$activated = false",
          "foreach $side in $field.sides:",
          [
            "foreach $condition in $side_conditions:",
            [
              "if !func_call(has_side_condition: $side $condition):",
              ["continue"],
              "if !$activated:",
              ["$activated = true", "log_activate: with_target"],
              "remove_side_condition: $side $condition"
            ]
          ]
        ]
      }
    }
  },
  "steelyspirit": {
    "name": "Steely Spirit",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_ally_base_power": ["if $move.type == steel:", ["return $base_power * 3/2"]]
      }
    }
  },
  "perishbody": {
    "name": "Perish Body",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": [
          "if func_call(move_makes_contact: $move):",
          ["log_ability", "add_volatile: $source perishsong", "add_volatile: $target perishsong"]
        ]
      }
    }
  },
  "wanderingspirit": {
    "name": "Wandering Spirit",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": [
          "if func_call(move_makes_contact: $move):",
          ["add_volatile: $source swapabilities"]
        ]
      }
    }
  },
  "gorillatactics": {
    "name": "Gorilla Tactics",
    "flags": [],
    "effect": {
      "delegates": ["item:choiceband"]
    }
  },
  "neutralizinggas": {
    "name": "Neutralizing Gas",
    "flags": ["NoEntrainment", "NoReceiver", "NoRolePlay", "NoSkillSwap", "NoTrace", "NoTransform"],
    "effect": {
      "callbacks": {
        "on_before_switch_in": [
          "log_ability",
          "# Use a pseudo-weather for suppression two reasons:",
          "# 1. A pseudo-weather affects all Mons on the field with one condition.",
          "# 2. Due to the implementation of how we avoid infinite recursion in effect callbacks, abilities cannot suppress other abilities.",
          "add_pseudo_weather: $this.id"
        ],
        "on_end": [
          "# If no other Mons have this ability on the field, remove the pseudo-weather.",
          "foreach $other in func_call(all_active_mons):",
          ["require $other == $target or !func_call(has_ability: $other $this.id) else return"],
          "log_end",
          "remove_pseudo_weather: $this.id"
        ]
      }
    },
    "condition": {
      "callbacks": {
        "suppress_mon_ability": [
          "# Do not suppress our own ability, so that we can trigger this condition to end.",
          "if $effect_state.started and $mon.ability != $this.id:",
          ["return true"]
        ],
        "on_field_start": [
          "# If a Mon's ability is suppressed, end it.",
          "# Note that `end_ability` has no effect if the ability was already ended elsewhere, or never started.",
          "foreach $mon in func_call(all_active_mons_in_speed_order):",
          ["if $mon.can_suppress_ability:", ["end_ability: $mon silent"]]
        ],
        "on_field_end": [
          "# Restart abilities.",
          "# Note that `start_ability` has no effect if an ability is still suppressed.",
          "foreach $mon in func_call(all_active_mons_in_speed_order):",
          ["start_ability: $mon silent"]
        ]
      }
    }
  },
  "pastelveil": {
    "name": "Pastel Veil",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_start": ["run_event_on_mon_ability: Update"],
        "on_update": [
          "$activated = false",
          "foreach $ally in func_call(allies_and_self: $mon):",
          [
            "if [psn, tox] has $ally.status:",
            [
              "if !$activated:",
              ["$activated = true", "log_activate: with_target"],
              "cure_status: $ally"
            ]
          ]
        ],
        "on_ally_switch_in": [
          "if [psn, tox] has $mon.status:",
          [
            "log_activate: with_target with_source use_effect_state_target_as_source",
            "cure_status: $mon"
          ]
        ],
        "on_ally_set_status": [
          "if [psn, tox] has $status:",
          [
            "if $effect.is_move and !$effect.is_move_secondary:",
            [
              "if $target == $effect_state.target:",
              ["log_immune: $target from_effect"],
              "else:",
              ["log_block: with_target with_source use_effect_state_target_as_source"]
            ],
            "return stopfail"
          ]
        ]
      }
    }
  },
  "hungerswitch": {
    "name": "Hunger Switch",
    "flags": ["NoEntrainment", "NoReceiver", "NoRolePlay", "NoSkillSwap", "NoTrace", "NoTransform"],
    "effect": {
      "callbacks": {
        "on_residual": [
          "require !$target.terastallized else return",
          "if $target.species == morpeko:",
          ["forme_change: $target morpekohangry"],
          "else:",
          ["forme_change: $target morpeko"]
        ]
      }
    }
  },
  "quickdraw": {
    "name": "Quick Draw",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_sub_priority": {
          "order": 1,
          "priority": -1,
          "program": [
            "if $move.category != status and func_call(chance: 3 10):",
            ["log_activate: with_target", "return 1"]
          ]
        }
      }
    }
  },
  "unseenfist": {
    "name": "Unseen Fist",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_source_try_hit": {
          "priority": 4,
          "program": [
            "if func_call(move_makes_contact: $move):",
            [
              "$move.effect_state.weaken_through_protection_effect = $this",
              "$move.effect_state.weaken_through_protection_source = $effect_state.target",
              "remove_move_flag: $move protect",
              "add_move_flag: $move weakenthroughprotection"
            ]
          ]
        }
      }
    }
  },
  "curiousmedicine": {
    "name": "Curious Medicine",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": [
          "foreach $ally in func_call(adjacent_allies: $target):",
          ["clear_boosts: $ally"]
        ]
      }
    }
  },
  "transistor": {
    "name": "Transistor",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_modify_atk": [
          "if $effect.is_defined and $effect.type == electric:",
          ["return $atk * 13/10"]
        ],
        "on_modify_spa": [
          "if $effect.is_defined and $effect.type == electric:",
          ["return $spa * 13/10"]
        ]
      }
    }
  },
  "dragonsmaw": {
    "name": "Dragon's Maw",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_modify_atk": [
          "if $effect.is_defined and $effect.type == dragon:",
          ["return $atk * 13/10"]
        ],
        "on_modify_spa": [
          "if $effect.is_defined and $effect.type == dragon:",
          ["return $spa * 13/10"]
        ]
      }
    }
  },
  "chillingneigh": {
    "name": "Chilling Neigh",
    "flags": [],
    "effect": {
      "delegates": ["ability:moxie"]
    }
  },
  "grimneigh": {
    "name": "Grim Neigh",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_after_fainted": [
          "require $effect.is_defined and $effect.is_move else return",
          "boost: $mon str('spa:{}', $count)"
        ]
      }
    }
  },
  "asone": {
    "name": "As One",
    "flags": ["NoEntrainment", "NoReceiver", "NoRolePlay", "NoSkillSwap", "NoTrace", "Permanent"],
    "effect": {
      "callbacks": {
        "on_before_start": [
          "$effect_state.activated = false",
          "clear_sub_abilities: $target",
          "if $target.species == calyrexice:",
          ["add_sub_ability: $target unnerve", "add_sub_ability: $target chillingneigh"],
          "else if $target.species == calyrexshadow:",
          ["add_sub_ability: $target unnerve", "add_sub_ability: $target grimneigh"],
          "else:",
          ["return"],
          "$effect_state.activated = true"
        ],
        "on_start": [
          "require !$effect_state.announced and $effect_state.activated else return",
          "log_ability",
          "$effect_state.announced = true"
        ]
      }
    }
  }
}
