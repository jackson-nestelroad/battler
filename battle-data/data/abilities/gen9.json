{
  "lingeringaroma": {
    "name": "Lingering Aroma",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": [
          "$ability = $source.ability",
          "require !func_call(ability_has_flag: $ability permanent) else return",
          "require $ability != $this.id else return",
          "require func_call(move_makes_contact: $move) else return",
          "set_ability: $source $this.id"
        ]
      }
    }
  },
  "seedsower": {
    "name": "Seed Sower",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": [
          "require func_call(move_makes_contact: $move) else return",
          "set_terrain: grassyterrain"
        ]
      }
    }
  },
  "thermalexchange": {
    "name": "Thermal Exchange",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_damaging_hit": ["require $move.type == fire else return", "boost: $target 'atk:1'"],
        "on_set_status": [
          "require $status.id == brn else return",
          "if $effect.is_move and !$effect.is_move_secondary:",
          ["log_immune: $target from_effect"],
          "return stopfail"
        ],
        "on_update": ["if $mon.status == brn:", ["cure_status: $mon"]]
      }
    }
  },
  "angershell": {
    "name": "Anger Shell",
    "flags": [],
    "effect": {
      "delegates": ["condition:hpactivatedabilitybase"],
      "callbacks": {
        "on_activate": ["boost: $target 'atk:1' 'spa:1' 'spe:1' 'def:-1' 'spd:-1'"]
      }
    }
  },
  "purifyingsalt": {
    "name": "Purifying Salt",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_set_status": [
          "if $effect.is_move and !$effect.is_move_secondary:",
          ["log_immune: $target from_effect"],
          "return stopfail"
        ],
        "on_add_volatile": [
          "if $volatile.id == yawn:",
          [
            "if $effect.is_move and !$effect.is_move_secondary:",
            ["log_immune: $target from_effect"],
            "return stopfail"
          ]
        ],
        "on_source_modify_atk": [
          "if $effect.is_defined and $effect.type == ghost:",
          ["return $atk / 2"]
        ],
        "on_source_modify_spa": [
          "if $effect.is_defined and $effect.type == ghost:",
          ["return $spa / 2"]
        ]
      }
    }
  },
  "wellbakedbody": {
    "name": "Well-Baked Body",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_try_hit": [
          "require $target != $source and $move.type == fire else return",
          "if !func_call(boost: $target 'def:2') and $report:",
          ["log_immune: $target from_effect"],
          "return stopfail"
        ]
      }
    }
  },
  "windrider": {
    "name": "Wind Rider",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_try_hit": [
          "require $target != $source and func_call(move_has_flag: $move wind) else return",
          "if !func_call(boost: $target 'atk:1') and $report:",
          ["log_immune: $target from_effect"],
          "return stopfail"
        ],
        "on_start": [
          "require func_call(has_side_condition: $target.side tailwind) else return",
          "boost: $target 'atk:1'"
        ],
        "on_side_side_condition_start": ["run_event_on_mon_ability: Start use_effect_state_target"]
      }
    }
  },
  "guarddog": {
    "name": "Guard Dog",
    "flags": ["Breakable"],
    "effect": {
      "delegates": ["ability:suctioncups", "condition:resistintimidateabilitybase"]
    }
  },
  "rockypayload": {
    "name": "Rocky Payload",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_modify_atk": ["if $effect.is_defined and $effect.type == rock:", ["return $atk * 3/2"]],
        "on_modify_spa": ["if $effect.is_defined and $effect.type == rock:", ["return $spa * 3/2"]]
      }
    }
  },
  "windpower": {
    "name": "Wind Power",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": [
          "require func_call(move_has_flag: $move wind) else return",
          "add_volatile: $target charge"
        ],
        "on_side_side_condition_start": [
          "require $condition.id == tailwind else return",
          "add_volatile: $effect_state.target charge"
        ]
      }
    }
  },
  "zerotohero": {
    "name": "Zero to Hero",
    "flags": [
      "NoEntrainment",
      "NoReceiver",
      "NoRolePlay",
      "NoSkillSwap",
      "NoTrace",
      "NoTransform",
      "Permanent"
    ],
    "effect": {
      "callbacks": {
        "on_after_switch_out": [
          "require func_call(base_species: $mon) == palafin else return",
          "require $mon.species != palafinhero else return",
          "forme_change: $mon palafinhero permanent",
          "$mon.effect_state.displayed = false"
        ],
        "on_switch_in": [
          "require func_call(base_species: $mon) == palafin else return",
          "require !$mon.effect_state.displayed and $mon.species == palafinhero else return",
          "log_activate: with_target",
          "$mon.effect_state.displayed = true"
        ]
      }
    }
  },
  "commander": {
    "name": "Commander",
    "flags": ["NoEntrainment", "NoReceiver", "NoRolePlay", "NoSkillSwap", "NoTrace"],
    "effect": {
      "callbacks": {
        "on_any_switch_in": ["activate_ability: $effect_state.target"],
        "on_start": ["activate_ability: $target"],
        "on_end": ["remove_volatile: $target commanding"],
        "on_activate": [
          "require !$target.needs_switch else return",
          "if func_call(base_species: $target) == tatsugiri:",
          [
            "$commanding_state = func_call(volatile_status_effect_state: $target commanding)",
            "if $commanding_state.is_defined:",
            ["$ally = $commanding_state.source"],
            "else:",
            [
              "foreach $mon in func_call(adjacent_allies):",
              [
                "if !$mon.needs_switch and func_call(base_species: $mon) == dondozo and !func_call(has_volatile: $mon commanded):",
                ["$ally = $mon"]
              ]
            ]
          ],
          "if !$ally:",
          ["remove_volatile: $target commanding", "return"],
          "if !func_call(has_volatile: $target commanding):",
          ["log_activate: with_target", "add_volatile: $ally commanded"]
        ]
      }
    }
  },
  "electromorphosis": {
    "name": "Electromorphosis",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": ["add_volatile: $target charge"]
      }
    }
  },
  "protosynthesis": {
    "name": "Protosynthesis",
    "flags": ["NoEntrainment", "NoReceiver", "NoRolePlay", "NoSkillSwap", "NoTrace", "NoTransform"],
    "effect": {
      "callbacks": {
        "on_start": ["run_event_on_mon_ability: WeatherChange"],
        "on_weather_change": [
          "$volatile_state = func_call(volatile_status_effect_state: $target $this.id)",
          "$weather = $field.effective_weather",
          "if $weather.is_defined and $weather.is_sunny:",
          ["add_volatile: $target $this.id"],
          "else if $volatile_state.is_defined and !$volatile_state.from_booster:",
          ["remove_volatile: $target $this.id"]
        ],
        "on_end": [
          "$volatile_state = func_call(volatile_status_effect_state: $target $this.id)",
          "require $volatile_state.is_defined else return",
          "$volatile_state.force_ended = true",
          "remove_volatile: $target $this.id"
        ]
      }
    },
    "condition": {
      "no_copy": true,
      "callbacks": {
        "on_start": [
          "if $source_effect.id == boosterenergy:",
          ["$effect_state.from_booster = true", "log_activate: with_target with_source_effect"],
          "else:",
          ["log_activate: with_target"],
          "$effect_state.best_stat = func_call(best_stat: $target unmodified)",
          "log_start: str('stat:{}', $effect_state.best_stat)"
        ],
        "on_modify_atk": ["if $effect_state.best_stat == atk:", ["return $atk * 13/10"]],
        "on_modify_def": ["if $effect_state.best_stat == def:", ["return $def * 13/10"]],
        "on_modify_spa": ["if $effect_state.best_stat == spa:", ["return $spa * 13/10"]],
        "on_modify_spd": ["if $effect_state.best_stat == spd:", ["return $spd * 13/10"]],
        "on_modify_spe": ["if $effect_state.best_stat == spe:", ["return $spe * 3/2"]],
        "on_end": ["if $effect_state.force_ended:", ["log_end: silent"], "else:", ["log_end"]]
      }
    }
  },
  "quarkdrive": {
    "name": "Quark Drive",
    "flags": ["NoEntrainment", "NoReceiver", "NoRolePlay", "NoSkillSwap", "NoTrace", "NoTransform"],
    "effect": {
      "callbacks": {
        "on_start": ["run_event_on_mon_ability: TerrainChange"],
        "on_terrain_change": [
          "$volatile_state = func_call(volatile_status_effect_state: $target $this.id)",
          "$terrain = $field.effective_terrain",
          "if $terrain.is_defined and $terrain == electricterrain:",
          ["add_volatile: $target $this.id"],
          "else if $volatile_state.is_defined and !$volatile_state.from_booster:",
          ["remove_volatile: $target $this.id"]
        ],
        "on_end": [
          "$volatile_state = func_call(volatile_status_effect_state: $target $this.id)",
          "require $volatile_state.is_defined else return",
          "$volatile_state.force_ended = true",
          "remove_volatile: $target $this.id"
        ]
      }
    },
    "condition": {
      "delegates": ["abilitycondition:protosynthesis"]
    }
  },
  "goodasgold": {
    "name": "Good as Gold",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_try_hit": [
          "require $move.category == status and $target != $source else return",
          "if $report:",
          ["log_immune: $target from_effect"],
          "return stop"
        ]
      }
    }
  },
  "vesselofruin": {
    "name": "Vessel of Ruin",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": ["log_ability"],
        "on_any_modify_spa": [
          "require !func_call(has_ability: $target $this.id) else return",
          "$ruined_spa = func_call(read_event_state_value: ruined_spa)",
          "if !$ruined_spa:",
          [
            "$ruined_spa = $effect_state.target",
            "save_event_state_value: ruined_spa $effect_state.target"
          ],
          "require $ruined_spa == $effect_state.target else return",
          "return $spa * 3/4"
        ]
      }
    }
  },
  "swordofruin": {
    "name": "Sword of Ruin",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": ["log_ability"],
        "on_any_modify_def": [
          "require !func_call(has_ability: $target $this.id) else return",
          "$ruined_def = func_call(read_event_state_value: ruined_def)",
          "if !$ruined_def:",
          [
            "$ruined_spa = $effect_state.target",
            "save_event_state_value: ruined_def $effect_state.target"
          ],
          "if $ruined_def != $effect_state.target:",
          ["return"],
          "return $def * 3/4"
        ]
      }
    }
  },
  "tabletsofruin": {
    "name": "Tablets of Ruin",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": ["log_ability"],
        "on_any_modify_atk": [
          "require !func_call(has_ability: $target $this.id) else return",
          "$ruined_atk = func_call(read_event_state_value: ruined_atk)",
          "if !$ruined_atk:",
          [
            "$ruined_spa = $effect_state.target",
            "save_event_state_value: ruined_atk $effect_state.target"
          ],
          "if $ruined_atk != $effect_state.target:",
          ["return"],
          "return $def * 3/4"
        ]
      }
    }
  },
  "beadsofruin": {
    "name": "Beads of Ruin",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": ["log_ability"],
        "on_any_modify_spd": [
          "require !func_call(has_ability: $target $this.id) else return",
          "$ruined_spd = func_call(read_event_state_value: ruined_spd)",
          "if !$ruined_spd:",
          [
            "$ruined_spa = $effect_state.target",
            "save_event_state_value: ruined_spd $effect_state.target"
          ],
          "if $ruined_spd != $effect_state.target:",
          ["return"],
          "return $def * 3/4"
        ]
      }
    }
  },
  "orichalcumpulse": {
    "name": "Orichalcum Pulse",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": ["set_weather: harshsunlight", "log_activate: with_target"],
        "on_modify_atk": [
          "$weather = $field.effective_weather",
          "if $weather.is_defined and $weather.is_sunny:",
          ["return $atk * 4/3"]
        ]
      }
    }
  },
  "hadronengine": {
    "name": "Hadron Engine",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": ["set_terrain: electricterrain", "log_activate: with_target"],
        "on_modify_spa": [
          "$terrain = $field.effective_terrain",
          "if $terrain.is_defined and $terrain.is_sunny:",
          ["return $spa * 4/3"]
        ]
      }
    }
  },
  "opportunist": {
    "name": "Opportunist",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_foe_after_boost": [
          "require $effect.id != $this.id and $effect.id != mirrorherb else return",
          "if !$effect_state.boosts:",
          ["$effect_state.boosts = func_call(boost_table)"],
          "foreach $boost in func_call(boostable_stats):",
          [
            "$value = func_call(get_boost: $boosts $boost)",
            "if $value > 0:",
            [
              "$current = func_call(get_boost: $effect_state.boosts $boost)",
              "$effect_state.boosts = func_call(set_boost: $effect_state.boosts $boost expr($current + $value))"
            ]
          ]
        ],
        "on_after_action": [
          "$boosts = func_call(effect_state_remove_key: $effect_state boosts)",
          "require $boosts.is_defined else return",
          "boost: $mon $boosts"
        ]
      }
    }
  },
  "cudchew": {
    "name": "Cud Chew",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_eat_item": [
          "require func_call(item_has_flag: $item berry) else return",
          "$effect_state.berry = $item.id",
          "$effect_state.counter = 2",
          "if $battle.in_residual:",
          ["$effect_state.counter = 1"]
        ],
        "on_residual": [
          "require $effect_state.berry.is_defined and $target.hp > 0 else return",
          "if $effect_state.counter > 0:",
          ["$effect_state.counter = $effect_state.counter - 1"],
          "require $effect_state.counter == 0 else return",
          "log_activate: with_target",
          "eat_given_item: $target $effect_state.berry",
          "effect_state_remove_key: $effect_state berry",
          "effect_state_remove_key: $effect_state counter"
        ]
      }
    }
  },
  "sharpness": {
    "name": "Sharpness",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_source_base_power": [
          "if func_call(move_has_flag: $move slicing):",
          ["return $base_power * 3/2"]
        ]
      }
    }
  },
  "supremeoverlord": {
    "name": "Supreme Overlord",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": [
          "require $target.side.total_fainted > 0 else return",
          "log_activate: with_target",
          "$fainted = func_call(min: $target.side.total_fainted 5)",
          "log_start: str('fallen:{}', $fainted) silent",
          "$effect_state.fallen = $fainted"
        ],
        "on_end": ["require $effect_state.fallen.is_defined else return", "log_end: silent"],
        "on_source_base_power": [
          "require $effect_state.fallen.is_defined and $effect_state.fallen > 0 else return",
          "return $base_power * (10 + $effect_state.fallen) / 10"
        ]
      }
    }
  },
  "costar": {
    "name": "Costar",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": [
          "$allies = func_call(adjacent_allies: $target)",
          "require !$allies.is_empty else return",
          "$ally = func_call(sample: $allies)",
          "require $ally.is_defined else return",
          "copy_boosts: $target $ally"
        ]
      }
    }
  },
  "toxicdebris": {
    "name": "Toxic Debris",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": [
          "$side = $source.side",
          "if func_call(is_ally: $source $target):",
          ["$side = $source.side.foe_side"],
          "require $move.category == physical else return",
          "$side_condition_state = func_call(side_condition_effect_state: $side toxicspikes)",
          "require !$side_condition_state or $side_condition_state.layers < 2 else return",
          "log_activate: with_target",
          "add_side_condition: $side toxicspikes"
        ]
      }
    }
  },
  "armortail": {
    "name": "Armor Tail",
    "flags": ["Breakable"],
    "effect": {
      "delegates": ["ability:dazzling"]
    }
  },
  "eartheater": {
    "name": "Earth Eater",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_try_hit": [
          "require $target != $source and $move.type == ground else return",
          "if func_call(heal: $target expr($target.base_max_hp / 4)) == 0 and $report:",
          ["log_immune: $target from_effect"],
          "return stopfail"
        ]
      }
    }
  },
  "myceliummight": {
    "name": "Mycelium Might",
    "flags": [],
    "effect": {
      "delegates": ["condition:ignoreabilitymovebase"],
      "callbacks": {
        "on_sub_priority": ["require $move.category == status else return", "return -1"]
      },
      "local_data": {
        "values": {
          "category": "status"
        }
      }
    }
  },
  "mindseye": {
    "name": "Mind's Eye",
    "flags": ["Breakable"],
    "effect": {
      "delegates": ["ability:keeneye"],
      "callbacks": {
        "on_use_move": ["$move.ignore_evasion = true"],
        "on_source_ignore_immunity": ["if func_call(has_type: $target ghost):", ["return true"]]
      }
    }
  },
  "supersweetsyrup": {
    "name": "Supersweet Syrup",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": [
          "require !$effect_state.triggered else return",
          "$effect_state.triggered = true",
          "log_ability",
          "foreach $target in func_call(adjacent_foes: $target):",
          ["boost: $target 'eva:-1'"]
        ]
      }
    }
  },
  "hospitality": {
    "name": "Hospitality",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": [
          "foreach $ally in func_call(adjacent_allies: $target):",
          ["heal: $ally expr($ally.base_max_hp / 4)"]
        ]
      }
    }
  },
  "toxicchain": {
    "name": "Toxic Chain",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_use_move": [
          "require $move.category != status else return",
          "$added_secondary = func_call(secondary_hit_effect)",
          "$added_secondary.chance = 3/10",
          "$added_secondary.target = func_call(hit_effect)",
          "$added_secondary.target.status = tox",
          "$added_secondary.source_effect = $this.id",
          "add_secondary_effect_to_move: $move $added_secondary"
        ]
      }
    }
  },
  "embodyaspect": {
    "name": "Embody Aspect",
    "flags": ["NoEntrainment", "NoReceiver", "NoRolePlay", "NoSkillSwap", "NoTrace", "NoTransform"],
    "effect": {
      "callbacks": {
        "on_start": [
          "require !$effect_state.activated else return",
          "if $target.species == ogerponcornerstonemasktera:",
          ["boost: $target 'def:1'"],
          "if $target.species == ogerponhearthflamemasktera:",
          ["boost: $target 'atk:1'"],
          "if $target.species == ogerpontealmasktera:",
          ["boost: $target 'spe:1'"],
          "if $target.species == ogerponwellspringmasktera:",
          ["boost: $target 'spd:1'"],
          "$effect_state.activated = true"
        ]
      }
    }
  },
  "terashift": {
    "name": "Tera Shift",
    "flags": [
      "NoEntrainment",
      "NoReceiver",
      "NoRolePlay",
      "NoSkillSwap",
      "NoTrace",
      "NoTransform",
      "Permanent"
    ],
    "effect": {
      "callbacks": {
        "on_switch_in": [
          "if $mon.species == terapagos:",
          ["log_activate: with_target", "forme_change: $mon terapagosterastal permanent"]
        ]
      }
    }
  },
  "terashell": {
    "name": "Tera Shell",
    "flags": ["Breakable", "NoEntrainment", "NoReceiver", "NoRolePlay", "NoSkillSwap", "NoTrace"],
    "effect": {
      "callbacks": {
        "on_modify_effectiveness": [
          "require $effect.is_move else return",
          "if $effect.effect_state.resisted:",
          ["return -1"],
          "require $effect.category != status and $effect.type != none else return",
          "require !func_call(check_move_immunity: $target $effect) else return",
          "require $modifier >= 0 and $target.hp >= $target.max_hp else return",
          "log_activate: with_target",
          "$effect.effect_state.resisted = true",
          "return -1"
        ]
      }
    }
  },
  "teraformzero": {
    "name": "Teraform Zero",
    "flags": ["NoEntrainment", "NoReceiver", "NoRolePlay", "NoSkillSwap", "NoTrace"],
    "effect": {
      "callbacks": {
        "on_start": [
          "require $field.weather.is_defined or $field.terrain.is_defined else return",
          "log_ability",
          "clear_weather",
          "clear_terrain"
        ]
      }
    }
  },
  "poisonpuppeteer": {
    "name": "Poison Puppeteer",
    "flags": ["NoEntrainment", "NoReceiver", "NoRolePlay", "NoSkillSwap", "NoTrace"],
    "effect": {
      "callbacks": {
        "on_source_after_set_status": [
          "require func_call(base_species: $effect_state.target) == pecharunt else return",
          "require $effect.is_move else return",
          "require [psn, tox] has $status.id else return",
          "add_volatile: $target confusion"
        ]
      }
    }
  },
  "piercingdrill": {
    "name": "Piercing Drill",
    "flags": [],
    "effect": {
      "delegates": ["ability:unseenfist"]
    }
  },
  "dragonize": {
    "name": "Dragonize",
