  "magicbounce": {
    "name": "Magic Bounce",
    "flags": ["Breakable"],
    "effect": {
      "delegates": ["movecondition:magiccoat"],
      "callbacks": {
        "on_start": ["# No log."]
      }
    }
  },
  "sapsipper": {
    "name": "Sap Sipper",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_try_hit": {
          "priority": 1,
          "program": [
            "require $target != $source and $move.type == grass else return",
            "if !func_call(boost: $target 'atk:1') and $report:",
            ["log_immune: $target from_effect"],
            "return stopfail"
          ]
        },
        "on_side_try_hit_side": [
          "require $move.source != $effect_state.target and $move.type == grass else return",
          "boost: $effect_state.target 'atk:1'"
        ]
      }
    }
  },
  "prankster": {
    "name": "Prankster",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_modify_priority": [
          "if $move.category == status:",
          ["$move.effect_state.prankster = true", "return $priority + 1"]
        ],
        "on_use_move": [
          "if $user.non_external_active_move.is_defined and $user.non_external_active_move.effect_state.prankster:",
          ["$move.effect_state.prankster = true"]
        ]
      }
    }
  },
  "sandforce": {
    "name": "Sand Force",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_source_base_power": [
