{
  "pickpocket": {
    "name": "Pickpocket",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_after_move_secondary_effects": [
          "require $source != $target and func_call(move_makes_contact: $move) else return",
          "require $source.item.is_defined else return",
          "require !$target.item else return",
          "require !$target.needs_switch else return",
          "require !$target.force_switch else return",
          "require !$source.needs_switch else return",
          "require func_call(set_item: $target $source.item dry_run) else return",
          "require !!assign($item = func_call(take_item: $source)) else return",
          "set_item: $target $item"
        ]
      }
    }
  },
  "sheerforce": {
    "name": "Sheer Force",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_use_move": [
          "require !$move.secondary_effects.is_empty else return",
          "$move.secondary_effects = []",
          "$move.user_effect = undefined",
          "$move.ignore_all_secondary_effects = true"
        ],
        "on_source_base_power": [
          "if $move.ignore_all_secondary_effects:",
          ["return $base_power * 13/10"]
        ]
      }
    }
  },
  "contrary": {
    "name": "Contrary",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_change_boosts": [
          "foreach $boost in func_call(boostable_stats):",
          [
            "$val = func_call(get_boost: $boosts $boost)",
            "$boosts = func_call(set_boost: $boosts $boost expr(-1 * $val))"
          ],
          "return $boosts"
        ]
      }
    }
  },
  "unnerve": {
    "name": "Unnerve",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": [
          "require !$effect_state.unnerved else return",
          "log_ability",
          "$effect_state.unnerved = true"
        ],
        "on_end": ["$effect_state.unnerved = false"],
        "on_foe_try_eat_item": ["return !$effect_state.unnerved"]
      }
    }
  },
  "defiant": {
    "name": "Defiant",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_after_each_boost": [
          "require $source.is_defined and !func_call(is_ally: $target $source) else return",
          "if $value < 0:",
          ["boost: $target 'atk:2'"]
        ]
      }
    }
  },
  "defeatist": {
    "name": "Defeatist",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_modify_atk": ["if $target.hp <= $target.max_hp / 2:", ["return $atk / 2"]],
        "on_modify_spa": ["if $target.hp <= $target.max_hp / 2:", ["return $spa / 2"]]
      }
    }
  },
  "cursedbody": {
    "name": "Cursed Body",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": [
          "require !func_call(has_volatile: $source disable) else return",
          "require !$move.upgraded else return",
          "require !func_call(move_has_flag: $move future) else return",
          "require $move.id != struggle else return",
          "if func_call(chance: 3 10):",
          ["add_volatile: $source disable"]
        ]
      }
    }
  },
  "healer": {
    "name": "Healer",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_residual": [
          "foreach $ally in func_call(adjacent_allies: $target):",
          [
            "if $ally.status.is_defined and func_call(chance: 3 10):",
            ["log_activate: with_target", "cure_status: $ally"]
          ]
        ]
      }
    }
  },
  "friendguard": {
    "name": "Friend Guard",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_any_modify_damage": [
          "if $target != $effect_state.target and func_call(is_ally: $target $effect_state.target):",
          ["return $damage * 3/4"]
        ]
      }
    }
  },
  "weakarmor": {
    "name": "Weak Armor",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": ["if $move.category == physical:", ["boost: $target 'def:-1' 'spe:2'"]]
      }
    }
  },
  "heavymetal": {
    "name": "Heavy Metal",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_modify_weight": {
          "priority": 1,
          "program": ["return $weight * 2"]
        }
      }
    }
  },
  "lightmetal": {
    "name": "Light Metal",
    "flags": ["Breakable"],
    "callbacks": {
      "on_modify_weight": {
        "priority": 1,
        "program": ["return $weight / 2"]
      }
    }
  },
  "multiscale": {
    "name": "Multiscale",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_source_modify_damage": ["if $target.hp >= $target.max_hp:", ["return $damage / 2"]]
      }
    }
  },
  "toxicboost": {
    "name": "Toxic Boost",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_source_base_power": [
          "if ($source.status == psn or $source.status == tox) and $move.category == physical:",
          ["return $base_power * 3/2"]
        ]
      }
    }
  },
  "flareboost": {
    "name": "Flare Boost",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_source_base_power": [
          "if $source.status == brn and $move.category == physical:",
          ["return $base_power * 3/2"]
        ]
      }
    }
  },
  "harvest": {
    "name": "Harvest",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_residual": [
          "$weather = func_call(effective_weather: $target)",
          "require $weather.is_defined and $weather.is_sunny or !func_call(chance: 1 2) else return",
          "require !$target.item else return",
          "require $target.last_item.is_defined else return",
          "require func_call(item_has_flag: $target.last_item berry) else return",
          "$item = $target.last_item",
          "$target.last_item = undefined",
          "set_item: $target $item"
        ]
      }
    }
  },
  "telepathy": {
    "name": "Telepathy",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_try_hit": [
          "if $target != $source and func_call(is_ally: $target $source):",
          ["if $report:", ["log_activate: with_target"], "return stopfail"]
        ]
      }
    }
  },
  "moody": {
    "name": "Moody",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_residual": [
          "$possible_boosts = []",
          "foreach $stat in func_call(boostable_stats):",
          [
            "if $stat == acc or $stat == eva:",
            ["continue"],
            "if func_call(can_boost: $target str('{}:1', $stat)):",
            ["$possible_boosts = func_call(append: $possible_boosts $stat)"]
          ],
          "$boost = func_call(sample: $possible_boosts)",
          "$possible_drops = []",
          "foreach $stat in func_call(boostable_stats):",
          [
            "if $stat == acc or $stat == eva or $stat == $boost:",
            ["continue"],
            "if func_call(can_boost: $target str('{}:-1', $stat)):",
            ["$possible_drops = func_call(append: $possible_drops $stat)"]
          ],
          "$drop = func_call(sample: $possible_drops)",
          "$boosts = func_call(boost_table)",
          "if $boost.is_defined:",
          ["$boosts = func_call(set_boost: $boosts $boost 2)"],
          "if $drop.is_defined:",
          ["$boosts = func_call(set_boost: $boosts $drop -1)"],
          "boost: $target $boosts"
        ]
      }
    }
  },
  "overcoat": {
    "name": "Overcoat",
    "flags": ["Breakable"],
    "effect": {
      "delegates": ["item:safetygoggles"],
      "callbacks": {
        "on_try_hit": [
          "if func_call(move_has_flag: $move powder) and $target != $source and func_call(check_immunity: $target powderdust):",
          ["if $report:", ["log_immune: $target from_effect"], "return stopfail"]
        ]
      }
    }
  },
  "poisontouch": {
    "name": "Poison Touch",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_use_move": [
          "require $move.category != status and func_call(move_makes_contact: $move) else return",
          "$added_secondary = func_call(secondary_hit_effect)",
          "$added_secondary.chance = 3/10",
          "$added_secondary.target = func_call(hit_effect)",
          "$added_secondary.target.status = psn",
          "$added_secondary.source_effect = $this.id",
          "add_secondary_effect_to_move: $move $added_secondary"
        ]
      }
    }
  },
  "regenerator": {
    "name": "Regenerator",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_switch_out": ["heal: $mon expr($mon.base_max_hp / 3)"]
      }
    }
  },
  "bigpecks": {
    "name": "Big Pecks",
    "flags": ["Breakable"],
    "effect": {
      "delegates": ["condition:preventstatdropabilitybase"],
      "local_data": {
        "values": {
          "stat": "def"
        }
      }
    }
  },
  "sandrush": {
    "name": "Sand Rush",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_modify_spe": ["if $field.weather == sandstormweather:", ["return $spe * 2"]],
        "on_immunity": ["if $effect.id == sandstormweather:", ["return false"]]
      }
    }
  },
  "wonderskin": {
    "name": "Wonder Skin",
    "flags": ["Breakable"],
    "effect": {
      "callbacks": {
        "on_modify_accuracy": ["if $move.category == status:", ["return 50"]]
      }
    }
  },
  "analytic": {
    "name": "Analytic",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_source_base_power": [
          "foreach $mon in func_call(all_active_mons):",
          ["require !func_call(will_move_this_turn: $mon) else return"],
          "return $base_power * 13/10"
        ]
      }
    }
  },
  "illusion": {
    "name": "Illusion",
    "flags": ["NoEntrainment", "NoReceiver", "NoRolePlay", "NoSkillSwap", "NoTrace"],
    "effect": {
      "callbacks": {
        "on_switching_in": [
          "foreach $target in func_call(reverse: $mon.player.team_by_effective_position):",
          [
            "if $target == $mon or $target.exited:",
            ["continue"],
            "set_illusion: $mon $target",
            "break"
          ]
        ],
        "on_damaging_hit": [
          "require $target.illusion.is_defined else return",
          "end_ability: $target silent"
        ],
        "on_end": [
          "require $target.illusion.is_defined else return",
          "end_illusion: $target",
          "log_end"
        ],
        "on_before_terastallization": [
          "require $mon.illusion.is_defined else return",
          "$base_species = func_call(lookup_base_species: $mon.illusion)",
          "if [ogerpon, terapagos] has $base_species:",
          ["end_ability: $mon silent"]
        ]
      }
    }
  },
  "imposter": {
    "name": "Imposter",
    "flags": ["NoEntrainment", "NoReceiver", "NoRolePlay", "NoTrace"],
    "effect": {
      "callbacks": {
        "on_switch_in": [
          "$position = $format.mons_per_side - $mon.position - 1",
          "$target = func_call(mon_in_position: $mon.foe_side $position)",
          "if $target.is_defined:",
          ["transform_into: $mon $target"]
        ]
      }
    }
  },
  "infiltrator": {
    "name": "Infiltrator",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_use_move": ["$move.effect_state.infiltrates = true"]
      }
    }
  },
  "mummy": {
    "name": "Mummy",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": [
          "require !func_call(ability_has_flag: $source.ability permanent) and $source.ability != $this.id else return",
          "if func_call(move_makes_contact: $move):",
          ["set_ability: $source $this.id"]
        ]
      }
    }
  },
  "moxie": {
    "name": "Moxie",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_after_fainted": [
          "require $effect.is_defined and $effect.is_move else return",
          "boost: $mon str('atk:{}', $count)"
        ]
      }
    }
  },
  "justified": {
    "name": "Justified",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": ["if $move.type == dark:", ["boost: $target 'atk:1'"]]
      }
    }
  },
  "rattled": {
    "name": "Rattled",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": ["if [dark, bug, ghost] has $move.type:", ["boost: $target 'spe:1'"]],
        "on_after_boost": [
          "if $effect.id == intimidate and $boosts.atk != 0:",
          ["boost: $target 'spe:1'"]
        ]
