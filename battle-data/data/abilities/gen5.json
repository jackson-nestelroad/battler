  "ironbarbs": {
    "name": "Iron Barbs",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": [
          "if func_call(move_makes_contact: $move):",
          ["damage: $source expr($source.base_max_hp / 8)"]
