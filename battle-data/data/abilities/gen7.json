{
  "stamina": {
    "name": "Stamina",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": ["boost: $target 'def:1'"]
      }
    }
  },
  "wimpout": {
    "name": "Wimp Out",
    "flags": [],
    "effect": {
      "delegates": ["ability:emergencyexit"]
    }
  },
  "emergencyexit": {
    "name": "Emergency Exit",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_after_damage": [
          "# Move damage is handled together after secondary effects.",
          "if $effect.is_move or $effect.id == confusion:",
          ["return"],
          "$original_hp = $target.hp + $damage",
          "activate_ability: $original_hp"
        ],
        "on_after_move_secondary_effects_damage": [
          "if $damage == 0:",
          ["return"],
          "activate_ability: $original_hp"
        ],
        "on_activate": {
          "metadata": {
            "parameters": ["original_hp"]
          },
          "program": [
            "if !$original_hp or $battle.ending or !func_call(can_switch: $target.player):",
            ["return"],
            "if $target.hp == 0 or $target.force_switch or $target.needs_switch or $target.is_away_from_field:",
            ["return"],
            "$half = $target.max_hp / 2",
            "if $original_hp > $half and $target.hp <= $half:",
            [
              "foreach $mon in func_call(all_active_mons):",
              ["set_needs_switch: $mon false"],
              "log_activate: with_target",
              "switch_out: $target"
            ]
          ]
        }
      }
    }
  },
  "watercompaction": {
    "name": "Water Compaction",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": [
          "if $move.type == water:",
          ["boost: $target 'def:2'"]
        ]
      }
    }
  },
  "merciless": {
    "name": "Merciless",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_modify_crit_ratio": [
          "if $target.is_defined and $target.status.is_defined and [psn, tox] has $target.status:",
          ["return 5"]
        ]
      }
    }
  },
  "shieldsdown": {
    "name": "Shields Down",
    "flags": ["Permanent"],
    "effect": {
      "callbacks": {
        "on_start": ["run_event_on_mon_ability: Residual"],
        "on_residual": [
          "$base_species = func_call(base_species: $target)",
          "if $base_species != minior or $target.transformed or $target.hp == 0:",
          ["return"],
          "if $target.hp > $target.max_hp / 2:",
          ["forme_change: $target miniormeteor"],
          "else:",
          [
            "# Original base species preserves the Minior color.",
            "forme_change: $target $target.original_base_species"
          ]
        ],
        "on_set_status": [
          "if $target.species != miniormeteor or $target.transformed:",
          ["return"],
          "if $effect.is_move and !$effect.is_move_secondary:",
          ["log_immune: from_effect"],
          "return false"
        ],
        "on_add_volatile": [
          "if $target.species != miniormeteor or $target.transformed:",
          ["return"],
          "if $volatile.id == yawn:",
          [
            "if $effect.is_move and !$effect.is_move_secondary:",
            ["log_immune: from_effect"],
            "return false"
          ]
        ]
      }
    }
  },
  "stakeout": {
    "name": "Stakeout",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_modify_atk": [
          "if $source.is_defined and $source.newly_switched:",
          ["return $atk * 2"]
        ],
        "on_modify_spa": [
          "if $source.is_defined and $source.newly_switched:",
          ["return $spa * 2"]
        ]
      }
    }
  },
  "waterbubble": {
    "name": "Water Bubble",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_source_modify_atk": ["if $move.type == fire:", ["return $atk / 2"]],
        "on_source_modify_spa": ["if $move.type == fire:", ["return $spa / 2"]],
        "on_modify_atk": ["if $move.type == water:", ["return $atk * 2"]],
        "on_modify_spa": ["if $move.type == water:", ["return $spa * 2"]],
        "on_set_status": [
          "if $status.id != brn:",
          ["return"],
          "if $effect.is_move and !$effect.is_move_secondary:",
          ["log_immune: $target from_effect"],
          "return false"
        ],
        "on_update": [
          "if $mon.status == brn:",
          ["log_activate: with_target", "cure_status: $mon"]
        ]
      }
    }
  },
  "steelworker": {
    "name": "Steelworker",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_modify_atk": [
          "if $effect.is_defined and $effect.type == steel:",
          ["return $atk * 3/2"]
        ],
        "on_modify_spa": [
          "if $effect.is_defined and $effect.type == steel:",
          ["return $spa * 3/2"]
        ]
      }
    }
  },
  "berserk": {
    "name": "Berserk",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_after_damage": [
          "$effect_state.berserk_may_activate = true",
          "# Move damage is handled together after secondary effects.",
          "if $effect.is_move or $effect.id == confusion:",
          ["return"],
          "$original_hp = $target.hp + $damage",
          "activate_ability: $original_hp"
        ],
        "on_after_move_secondary_effects_damage": [
          "if $damage == 0:",
          ["return"],
          "activate_ability: $original_hp"
        ],
        "on_try_eat_item": [
          "# Healing items are consumed because HP dropped below a threshold.",
          "# If we received damage as part of a move, don't consume the berry until Berserk has activated.",
          "$healing_items = [aguavberry, enigmaberry, figyberry, iapapaberry, magoberry, sitrusberry, wikiberry, oranberry, berryjuice]",
          "if $healing_items has $item.id and $effect_state.berserk_may_activate:",
          ["return false"]
        ],
        "on_activate": {
          "metadata": {
            "parameters": ["original_hp"]
          },
          "program": [
            "$effect_state.berserk_may_activate = false",
            "if !$original_hp:",
            ["return"],
            "if $target.hp == 0",
            ["return"],
            "$half = $target.max_hp / 2",
            "if $original_hp > $half and $target.hp <= $half:",
            ["boost: $target 'spa:1'"]
          ]
        }
      }
    }
  },
  "slushrush": {
    "name": "Slush Rush",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_modify_spe": [
          "$weather = func_call(effective_weather: $target)",
          "if $weather.is_snowing:",
          ["return $spe * 2"]
        ]
      }
    }
  },
  "longreach": {
    "name": "Long Reach",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_use_move": ["remove_move_flag: $move contact"]
      }
    }
  },
  "liquidvoice": {
    "name": "Liquid Voice",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_modify_move_type": [
          "if func_call(move_has_flag: $effect sound):",
          ["return water"]
        ]
      }
    }
  },
  "triage": {
    "name": "Triage",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_modify_priority": [
          "if func_call(move_has_flag: $move heal):",
          ["return $priority + 3"]
        ]
      }
    }
  },
  "galvanize": {
    "name": "Galvanize",
    "flags": [],
    "effect": {
      "delegates": ["condition:modifynormaltypemoveabilitybase"],
      "local_data": {
        "values": {
          "type": "electric"
        }
      }
    }
  },
  "surgesurfer": {
    "name": "Surge Surfer",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_modify_spe": [
          "if $target.effective_terrain == electricterrain:",
          ["return $spe * 2"]
        ]
      }
    }
  },
  "schooling": {
    "name": "Schooling",
    "flags": ["Permanent"],
    "effect": {
      "callbacks": {
        "on_start": ["run_event_on_mon_ability: Residual"],
        "on_residual": [
          "$base_species = func_call(base_species: $target)",
          "if $base_species != wishiwashi or $target.transformed or $target.hp == 0:",
          ["return"],
          "if $target.hp > $target.max_hp / 4:",
          ["forme_change: $target wishiwashischool"],
          "else:",
          ["forme_change: $target wishiwashi"]
        ]
      }
    }
  },
  "disguise": {
    "name": "Disguise",
    "flags": ["Permanent"],
    "effect": {
      "callbacks": {
        "on_damage": {
          "priority": 1,
          "program": [
            "if !$effect.is_move or !([mimikyu, mimikyutotemdisguised] has $target.species) or $target.transformed:",
            ["return"],
            "activate_ability",
            "return 0"
          ]
        },
        "on_activate": [
          "$species = mimikyubusted",
          "if $target.species == mimikyutotemdisguised:",
          ["$species = mimikyutotembusted"],
          "forme_change: $target $species permanent",
          "damage: $target expr($target.base_max_hp / 8)"
        ],
        "on_critical_hit": [
          "if !([mimikyu, mimikyutotemdisguised] has $target.species) or $target.transformed:",
          ["return"],
          "if func_call(move_hit_data_has_flag_against_target: $move $target hitsubstitute):",
          ["return"],
          "if !func_call(check_move_immunity: $target $move):",
          ["return"],
          "return false"
        ],
        "on_effectiveness": [
          "if $effect.category == status:",
          ["return"],
          "if !func_call(run_event_on_mon_ability: CriticalHit):",
          ["return 0"]
        ]
      }
    }
  },
  "battlebond": {
    "name": "Battle Bond",
    "flags": ["Permanent"],
    "effect": {
      "callbacks": {
        "on_after_fainted": [
          "if !$effect or !$effect.is_move:",
          ["return"],
          "if $mon.species != greninjabattlebond or $mon.hp == 0 or $mon.transformed or $mon.foe_side.mons_left == 0:",
          ["return"],
          "if $mon.effect_state.battle_bond_triggered:",
          ["return"],
          "activate_ability"
        ],
        "on_activate": [
          "log_activate: with_target",
          "boost: $target 'atk:1' 'spa:1' 'spe:1'",
          "forme_change: greninjabattlebond greninjaash permanent"
        ],
        "on_use_move": [
          "if $move.id == watershuriken and $source.species == greninjaash and !$source.transformed:",
          ["$move.base_power = $move.base_power + 5", "$move.multihit = 3"]
        ]
      }
    }
  },
  "powerconstruct": {
    "name": "Power Construct",
    "flags": ["Permanent"],
    "effect": {
      "callbacks": {
        "on_residual": [
          "$base_species = func_call(base_species: $target)",
          "if $base_species != zygarde or $target.transformed or $target.hp == 0:",
          ["return"],
          "if $target.species == zygardecomplete or $target.hp > $target.max_hp / 2:",
          ["return"],
          "forme_change: $target zygardecomplete permanent revertible"
        ]
      }
    }
  },
  "corrosion": {
    "name": "Corrosion",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_immunity": {
          "order": 1,
          "program": [
            "if [psn, tox] has $effect.id:",
            [
              "skip_effect_callback: poisontype",
              "skip_effect_callback: steeltype"
            ]
          ]
        }
      }
    }
  },
  "comatose": {
    "name": "Comatose",
    "flags": ["Permanent"],
    "effect": {
      "callbacks": {
        "is_asleep": ["return true"]
      }
    }
  },
  "queenlymajesty": {
    "name": "Queenly Majesty",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_foe_try_move": [
          "$target_all_exceptions = [perishsong, flowershield, rototiller]",
          "if $move.target == foeside or ($move.target == all and !($target_all_exceptions has $move.id)):",
          ["return"],
          "if $move.priority == 0:",
          ["return"],
          "if !$target.is_defined or !func_call(is_ally: $target $effect_state.target):",
          ["return"],
          "log_cant: with_source use_effect_state_target_as_source",
          "return false"
        ]
      }
    }
  },
  "innardsout": {
    "name": "Innards Out",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_damaging_hit": {
          "order": 1,
          "program": [
            "if $target.hp > 0:",
            ["return"],
            "$original_hp = func_call(move_target_original_hp: $move $target",
            "if !$original_hp:",
            ["return"],
            "damage: $source func_call(undynamaxed_hp_calculation: $target $original_hp)"
          ]
        }
      }
    }
  },
  "dancer": {
    "name": "Dancer",
    "flags": [],
    "effect": {
      "callbacks": {
        "on_start": ["add_pseudo_weather: $this.id"],
        "on_end": [
          "# If no other Mons have this ability on the field, remove the pseudo-weather.",
          "foreach $other in func_call(all_active_mons):",
          [
            "if $other != $target and func_call(has_ability: $other $this.id):",
            ["return"]
          ],
          "remove_pseudo_weather: $this.id"
        ]
      }
    },
    "condition": {
      "callbacks": {
        "on_after_move": [
          "if !func_call(move_has_flag: $move dance) or !$success or $move.external:",
          ["return"],
          "$dancers = []",
          "foreach $mon in func_call(reverse: func_call(all_active_mons_in_speed_order_and_ability_effect_order)):",
          [
            "if $mon == $user:",
            ["continue"],
            "if func_call(has_ability: $mon $this.id) and !$mon.is_semi_invulnerable:",
            ["$dancers = func_call(append: $dancers $mon)"]
          ],
          "foreach $dancer in $dancers:",
          [
            "faint_messages",
            "if $battle.ending:",
            ["return"],
            "if $dancer.fainted:",
            ["return"],
            "log_activate: with_target $dancer",
            "if func_call(is_ally: $dancer $user):",
            ["$move_target = $target"],
            "else:",
            ["$move_target = $user"],
            "$dancer_move = func_call(new_active_move: $move.id $dancer)",
            "use_active_move: $dancer $dancer_move $move_target use_effect_as_source_effect preventable"
          ]
        ]
      }
    }
  },
