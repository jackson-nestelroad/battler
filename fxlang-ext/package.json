{
  "name": "fxlang-vscode",
  "displayName": "fxlang Support",
  "description": "Syntax highlighting and IntelliSense for fxlang DSL scripts.",
  "version": "0.1.0",
  "publisher": "jackson-nestelroad",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:fxlang",
    "onLanguage:json",
    "onLanguage:jsonc"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "fxlang",
        "aliases": [
            "fxlang"
        ]
      }
    ],
    "grammars": [
      {
        "language": "fxlang",
        "scopeName": "source.fxlang",
        "path": "./syntaxes/fxlang.tmLanguage.json"
      },
      {
        "scopeName": "fxlang.injection",
        "path": "./syntaxes/fxlang-injection.tmLanguage.json",
        "injectTo": ["source.json"]
      }
    ]
  },
  "scripts": {
    "update-metadata": "node ./tools/scrape-metadata.js",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^16.11.7",
    "@types/vscode": "^1.75.0",
    "typescript": "^4.9.4"
  }
}
