          [
            "$increment = $increment + 1"
            //^^^^^^^^^ variable.other
            //            ^^^^^^^^^ variable.other
            //                         ^ constant.numeric
          ],
          "if func_call(has_type: $target fire):",
          //^^ keyword.control
          //   ^^^^^^^^^ keyword.control
