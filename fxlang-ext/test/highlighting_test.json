          //            ^^^^^^ variable.other.constant
          //                     ^ constant.numeric
        ],
        "on_hit": [
        //^^^^^^ support.type.property-name.json
          "$increment = 1",
          //^^^^^^^^^ variable.other
          //            ^ constant.numeric
          "if func_call(get_stat: $source atk unmodified) > func_call(get_stat: $target atk unmodified):",
          //^^ keyword.control
