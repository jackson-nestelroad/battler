{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "scopeName": "fxlang.injection",
  "name": "fxlang-injection",
  "injectionSelector": "L:source.json, L:text.html.markdown",
  "patterns": [
    {
      "include": "#program_key"
    },
    {
      "include": "#callbacks_block"
    }
  ],
  "repository": {
    "program_key": {
      "patterns": [
        {
          "begin": "^(\\s*)(\"program\")\\s*:\\s*\\[(?=.*\\])",
          "beginCaptures": {
            "2": { "name": "support.type.property-name.json" }
          },
          "end": "\\](?=[^\\]]*$)",
          "patterns": [
            {
              "include": "#fxlang_array_element"
            }
          ]
        },
        {
          "begin": "^(\\s*)(\"program\")\\s*:\\s*\\[",
          "beginCaptures": {
            "2": { "name": "support.type.property-name.json" }
          },
          "end": "^\\1\\],?",
          "patterns": [
            {
              "include": "#fxlang_array_element"
            }
          ]
        }
      ]
    },
    "callbacks_block": {
      "begin": "^(\\s*)(\"callbacks\")\\s*:\\s*\\{",
      "beginCaptures": {
        "2": { "name": "support.type.property-name.json" }
      },
      "end": "^\\1\\},?",
      "patterns": [
        {
          "begin": "^(\\s*)(\"[a-zA-Z0-9_]+\")\\s*:\\s*\\[(?=.*\\])",
          "beginCaptures": {
            "2": { "name": "support.type.property-name.json" }
          },
          "end": "\\](?=[^\\]]*$)",
          "patterns": [
            {
              "include": "#fxlang_array_element"
            }
          ]
        },
        {
          "begin": "^(\\s*)(\"[a-zA-Z0-9_]+\")\\s*:\\s*\\[",
          "beginCaptures": {
            "2": { "name": "support.type.property-name.json" }
          },
          "end": "^\\1\\],?",
          "patterns": [
            {
              "include": "#fxlang_array_element"
            }
          ]
        },
        {
          "begin": "^(\\s*)(\"[a-zA-Z0-9_]+\")\\s*:\\s*\\{(?=.*\\})",
          "beginCaptures": {
            "2": { "name": "support.type.property-name.json" }
          },
          "end": "\\}(?=[^\\}]*$)",
          "patterns": [
            {
              "include": "#program_key"
            },
            {
              "match": "(\"[a-zA-Z0-9_]+\")\\s*:",
              "captures": {
                "1": { "name": "support.type.property-name.json" }
              }
            },
            {
              "include": "source.json"
            }
          ]
        },
        {
          "begin": "^(\\s*)(\"[a-zA-Z0-9_]+\")\\s*:\\s*\\{",
          "beginCaptures": {
            "2": { "name": "support.type.property-name.json" }
          },
          "end": "^\\1\\},?",
          "patterns": [
            {
              "include": "#program_key"
            },
            {
              "match": "^(\\s*)(\"[a-zA-Z0-9_]+\")\\s*:",
              "captures": {
                "2": { "name": "support.type.property-name.json" }
              }
            },
            {
              "include": "source.json"
            }
          ]
        }
      ]
    },







    "fxlang_array_element": {
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "include": "#statement"
        }
      ]
    },
    "statement": {
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "include": "#function_name"
        },
        {
          "include": "#keyword"
        },
        {
          "include": "#literal"
        },
        {
          "include": "#effect_state"
        },
        {
          "include": "#variable"
        },
        {
          "include": "#member_access"
        },
        {
          "include": "#string"
        },
        {
          "include": "#number"
        },
        {
          "include": "#flag"
        },
        {
          "include": "#unquoted_string"
        }
      ]
    },
    "comment": {
      "match": "#.*?(?=\"\\s*,?\\s*$)",
      "name": "comment.line.number-sign"
    },
    "keyword": {
      "patterns": [
        {
          "match": "\\b(if|else|foreach|in|return|continue|break|expr|func_call|str|or|and|has|hasany)\\b",
          "name": "keyword.control"
        }
      ]
    },


    "literal": {
      "patterns": [
        {
          "match": "\\b(true|false|undefined)\\b",
          "name": "constant.language"
        },
        {
          "match": "\\$this\\b",
          "name": "constant.language"
        }
      ]
    },
    "effect_state": {
      "match": "\\$effect_state\\b",
      "name": "entity.name.type"
    },
    "variable": {
      "match": "\\$[a-zA-Z_\\-][a-zA-Z0-9_\\-]*",
      "name": "variable.other"
    },
    "member_access": {
      "match": "(\\.)([a-zA-Z_\\-][a-zA-Z0-9_\\-]*)",
      "captures": {
        "1": { "name": "punctuation.accessor" },
        "2": { "name": "variable.other.constant" }
      }
    },
    "function_name": {
      "patterns": [
        {
          "match": "\\G\\s*(?!(?:if|else|foreach|in|return|continue|break|has|hasany|and|or|expr|func_call|str)\\b)([a-zA-Z_\\-][a-zA-Z0-9_\\-]*)",
          "captures": {
            "1": { "name": "entity.name.function" }
          }
        },
        {
          "match": "(\\bfunc_call)\\s*\\(\\s*([a-zA-Z_\\-][a-zA-Z0-9_\\-]*)",
          "captures": {
            "1": { "name": "keyword.control" },
            "2": { "name": "entity.name.function" }
          }
        }

      ]
    },
    "string": {
      "match": "'([^']|\\\\')*'",
      "name": "string.quoted.single"
    },
    "number": {
      "match": "(?<![a-zA-Z0-9_\\-])[\\+\\-]?[0-9]+(/[0-9]+)?\\b",
      "name": "constant.numeric"
    },
    "unquoted_string": {
      "match": "\\b[a-zA-Z_\\-][a-zA-Z0-9_\\-]*\\b",
      "name": "string.unquoted"
    },
    "flag": {
      "match": "\\b(from_effect|link|no_effect|no_events|no_forward|no_source|no_source_effect|residual|silent|use_effect_as_source_effect|use_effect_state_source|use_effect_state_source_as_source|use_effect_state_source_effect|use_effect_state_target|use_effect_state_target_as_source|use_source|use_source_as_origin|use_source_effect|use_target_as_origin|use_target_as_source|with_source|with_source_effect|with_target)\\b",
      "name": "constant.language"
    }
  }
}

