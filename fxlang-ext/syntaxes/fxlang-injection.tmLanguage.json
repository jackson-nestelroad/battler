{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "fxlang-injection",
  "scopeName": "fxlang.injection",
  "injectionSelector": "L:source.json",
  "patterns": [
    {
      "comment": "Entry Point: 'callbacks' field (Light Blue Key)",
      "begin": "(\"callbacks\")\\s*(:)\\s*",
      "beginCaptures": {
        "1": { "name": "variable.other.object.property.json" },
        "2": { "name": "punctuation.separator.dictionary.key-value.json" }
      },
      "end": "(?=[,\\}])",
      "patterns": [{ "include": "#fxlang-event-map-object" }]
    },
    {
      "comment": "Entry Point: 'program' field (Light Blue Key)",
      "begin": "(\"program\")\\s*(:)\\s*",
      "beginCaptures": {
        "1": { "name": "variable.other.object.property.json" },
        "2": { "name": "punctuation.separator.dictionary.key-value.json" }
      },
      "end": "(?=[,\\}])",
      "patterns": [{ "include": "#fxlang-program-choice" }]
    }
  ],
  "repository": {
    "fxlang-event-map-object": {
      "comment": "An object where every key is an event (colored Light Blue).",
      "begin": "\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.dictionary.begin.json" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.dictionary.end.json" }
      },
      "patterns": [
        {
          "comment": "Event Key (Light Blue), recursing into Program Choice",
          "begin": "(\"[a-zA-Z0-9_]+\")\\s*(:)\\s*",
          "beginCaptures": {
            "1": { "name": "variable.other.object.property.json" },
            "2": { "name": "punctuation.separator.dictionary.key-value.json" }
          },
          "end": "(?=[,\\}])",
          "patterns": [{ "include": "#fxlang-program-choice" }]
        },
        { "include": "source.json" },
        { "match": ",", "name": "punctuation.separator.dictionary.json" }
      ]
    },
    "fxlang-program-choice": {
      "comment": "Routes Strings/Arrays to code, and Objects to restricted Metadata Containers",
      "patterns": [
        { "include": "#fxlang-string-as-code" },
        { "include": "#fxlang-array-as-code" },
        { "include": "#fxlang-metadata-restricted-object" }
      ]
    },
    "fxlang-metadata-restricted-object": {
      "comment": "Object in code context. ALL keys are Light Blue, but ONLY 'program' contains code.",
      "begin": "\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.dictionary.begin.json" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.dictionary.end.json" }
      },
      "patterns": [
        {
          "comment": "The program key (Light Blue) recurses into code logic",
          "begin": "(\"program\")\\s*(:)\\s*",
          "beginCaptures": {
            "1": { "name": "variable.other.object.property.json" },
            "2": { "name": "punctuation.separator.dictionary.key-value.json" }
          },
          "end": "(?=[,\\}])",
          "patterns": [{ "include": "#fxlang-program-choice" }]
        },
        {
          "comment": "Other Metadata keys (Light Blue), but their values stay JSON",
          "begin": "(\"[a-zA-Z0-9_]+\")\\s*(:)\\s*",
          "beginCaptures": {
            "1": { "name": "variable.other.object.property.json" },
            "2": { "name": "punctuation.separator.dictionary.key-value.json" }
          },
          "end": "(?=[,\\}])",
          "patterns": [{ "include": "source.json" }]
        },
        { "include": "source.json" },
        { "match": ",", "name": "punctuation.separator.dictionary.json" }
      ]
    },
    "fxlang-string-as-code": {
      "patterns": [
        { "include": "#fxlang-single-word-call" },
        { "include": "#fxlang-full-statement-string" }
      ]
    },
    "fxlang-single-word-call": {
      "comment": "Parameterless call word.",
      "match": "(\")\\s*(?!(?:if|else|elseif|foreach|in|return|break|continue|and|or|not|has|hasany|func_call|expr|str)\\b)([a-zA-Z0-9_\\-]+)\\s*(\")",
      "captures": {
        "1": { "name": "punctuation.definition.string.begin.json" },
        "2": { "name": "entity.name.function.fxlang" },
        "3": { "name": "punctuation.definition.string.end.json" }
      }
    },
    "fxlang-full-statement-string": {
      "begin": "(\")(?:\\s*(?!(?:if|else|elseif|foreach|in|return|break|continue|and|or|not|has|hasany|func_call|expr|str)\\b)([a-zA-Z0-9_\\-]+)\\s*(:))?",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.json" },
        "2": { "name": "entity.name.function.fxlang" },
        "3": { "name": "punctuation.terminator.statement.fxlang" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.json" }
      },
      "contentName": "source.fxlang",
      "patterns": [{ "include": "source.fxlang" }]
    },
    "fxlang-array-as-code": {
      "begin": "\\[",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.array.begin.json" }
      },
      "end": "\\]",
      "endCaptures": {
        "0": { "name": "punctuation.definition.array.end.json" }
      },
      "patterns": [
        { "include": "#fxlang-program-choice" },
        { "match": ",", "name": "punctuation.separator.array.json" },
        { "include": "source.json" }
      ]
    }
  }
}
